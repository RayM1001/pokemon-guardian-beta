      },
      "en": {
        "meaning": ["growth", "renewal", "learning", "expansion"],
        "description": "Wood energy represents upward vitality — ideal when starting something new, building momentum, or breaking through stagnation."
      },
      "ja": {
        "meaning": ["成長", "芽吹き", "学び", "広がり"],
        "description": "木のエネルギーは上へ伸びる生命力。新しいことを始めたい、学びを深めたい、停滞を抜け出したいときにぴったりです。"
      }
    },
    "火": {
      "element": "火",
      "zh_tw": {
        "meaning": ["行動", "熱情", "曝光", "啟動"],
        "description": "火代表驅動與熱力，適合需要提振幹勁、加強人際存在感或推動事情快速啟動的時期。"
      },
