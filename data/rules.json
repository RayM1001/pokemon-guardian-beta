        "meaning": ["action", "passion", "visibility", "ignition"],
        "description": "Fire energy brings drive and warmth — great for pushing things forward, showing up more boldly, or reigniting motivation."
      },
      "ja": {
        "meaning": ["行動力", "情熱", "明るさ", "始動"],
        "description": "火のエネルギーは情熱と推進力。やる気を高めたい、存在感を出したい、物事を動かしたいときに力を発揮します。"
      }
    },
    "土": {
      "element": "土",
      "zh_tw": {
        "meaning": ["穩定", "承載", "休息", "生活感"],
        "description": "土代表厚實的承載能力，適合需要找回踏實感、建立規律日常或讓自己好好喘口氣的時期。"
      },
      "en": {
        "meaning": ["stability", "grounding", "rest", "daily rhythm"],
        "description": "Earth energy provides a steady foundation — helpful when you need to recharge, establish routines, or simply feel more settled in your day."
      },
      "ja": {
        "meaning": ["安定", "土台", "休息", "暮らし"],
        "description": "土のエネルギーはしっかりした土台。日常を整えたい、疲れを取りたい、地に足をつけたいときに支えてくれます。"
      }
    },
    "金": {
      "element": "金",
      "zh_tw": {
        "meaning": ["專注", "決策", "效率", "秩序"],
        "description": "金代表清晰的判斷力，適合需要整理思緒、做出決定或提升工作效率的時期。"
      },
      "en": {
        "meaning": ["focus", "decision", "efficiency", "structure"],
        "description": "Metal energy sharpens clarity — ideal for cutting through noise, making decisions with confidence, and creating order in your environment."
      },
      "ja": {
        "meaning": ["集中", "判断", "効率", "秩序"],
        "description": "金のエネルギーは鋭い判断力と集中力。頭を整理したい、決断したい、効率よく進めたいときに役立ちます。"
      }
    },
    "水": {
      "element": "水",
      "zh_tw": {
        "meaning": ["修復", "情緒", "直覺", "流動"],
        "description": "水代表深層的滋養與流動，適合情緒需要照料、壓力偏大或想找回直覺感知的時期。"
      },
      "en": {
        "meaning": ["healing", "emotion", "intuition", "flow"],
