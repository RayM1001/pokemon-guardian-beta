  "birthElementRules": {
    "_note": "出生資料簡化五行推算，非命理學精確計算，僅作輕量補位參考",
    "monthRules": {
      "scores": {
        "木": [2, 3, 4],
        "火": [5, 6, 7],
        "金": [8, 9, 10],
        "水": [11, 12, 1]
      },
      "weight": 2,
      "description": {
        "zh_tw": "出生月份對應四季五行，土貫穿四季故不列入月份主偏",
        "en": "Birth month maps to seasonal five elements; Earth spans all seasons and is excluded from monthly bias",
        "ja": "生まれた月は季節の五行に対応します。土は四季を貫くため月の主偏には含まれません"
      }
    },
    "dayDigitRules": {
      "scores": {
        "木": [1, 2],
        "火": [3, 4],
        "土": [5, 6],
        "金": [7, 8],
        "水": [9, 0]
      },
      "weight": 1,
      "description": {
        "zh_tw": "生日個位數字對應元素補充",
        "en": "The last digit of birth day maps to a supplementary element",
        "ja": "生まれた日の一の位が補足する五行に対応します"
      }
    },
    "hourRules": {
      "scores": {
        "水": ["子", "亥"],
        "木": ["寅", "卯"],
        "火": ["巳", "午"],
        "金": ["申", "酉"],
        "土": ["辰", "戌", "丑", "未"]
      },
      "chinesHourMap": {
        "子": "23:00–00:59",
        "丑": "01:00–02:59",
        "寅": "03:00–04:59",
        "卯": "05:00–06:59",
        "辰": "07:00–08:59",
        "巳": "09:00–10:59",
        "午": "11:00–12:59",
        "未": "13:00–14:59",
        "申": "15:00–16:59",
        "酉": "17:00–18:59",
        "戌": "19:00–20:59",
        "亥": "21:00–22:59"
      },
      "weight": 1,
      "description": {
        "zh_tw": "出生時段對應地支五行，以 24 小時制對照",
        "en": "Birth hour maps to earthly branch elements using 24-hour time ranges",
        "ja": "生まれた時刻を十二支の五行に対応させます（24時間制）"
      },
      "birthTime": {
        "optional": true,
        "unknownValue": "unknown",
        "unknownScore": 0,
        "unknownLabel": {
          "zh_tw": "不知道／略過",
          "en": "I don't know / Skip",
          "ja": "わからない／スキップ"
        }
      }
    }
  },

